# Sanity CMS
# Obtenir ces valeurs sur https://www.sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production

# Sanity API Token (lecture seule, pour les requêtes serveur si besoin)
# Générer un token sur https://www.sanity.io/manage -> API -> Tokens
SANITY_API_READ_TOKEN=your_read_token_here
